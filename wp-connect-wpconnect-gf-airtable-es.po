#. Translators: %1$s = Gravity Forms to Airtable settings page URL
#: includes/classes/class-gf-addon.php:332
msgid "No API key or token provided. Please enter a personal access token. You can update this in the <a href=\"%1$s\">Gravity Forms to Airtable settings</a>."
msgstr "No se ha proporcionado una clave API ni un token. Introduzca un token de acceso personal. Puede actualizarlo en los <a href=\"%1$s\">ajustes de Gravity Forms to Airtable</a>."

#. Translators: %1$s = Access token URL; %2$s = Gravity Forms to Airtable
#. settings page URL
#: includes/classes/class-gf-addon.php:323
msgid "Airtable API Keys will be deprecated by the end of January. Please replace your API key with a personal access token. You can <a href=\"%1$s\" target=\"_blank\" rel=\"noopener noreferer\">create an access token here</a>."
msgstr "Las Claves API de Airtable serán obsoletas a finales de enero. Por favor, reemplaza tu clave API con un token de acceso personal. Puedes <a href=\"%1$s\" target=\"_blank\" rel=\"noopener noreferer\">crear un token de acceso aquí</a>."

